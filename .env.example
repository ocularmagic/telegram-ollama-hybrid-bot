# Telegram
TELEGRAM_BOT_TOKEN=replace_me
BOT_USERNAME=your_bot_username

# Tavily live search
TAVILY_API_KEY=replace_me

# Optional: enables Ollama web search fallback if Tavily is unavailable
OLLAMA_API_KEY=

# Models
LOCAL_MODEL_1=qwen3:14b
LOCAL_MODEL_2=gemma3:12b
CLOUD_MODEL=kimi-k2.5:cloud
SEARCH_PLANNER_MODEL=built-in
SEARCH_RETRIEVAL_MODEL=tavily-search
TAVILY_SEARCH_DEPTH=basic

# Timeouts
EVIDENCE_TIMEOUT_SECONDS=300
LOCAL_MODEL_TIMEOUT_SECONDS=300
FINAL_TIMEOUT_SECONDS=600

# Search pool shaping
SEARCH_QUERY_LIMIT=3
SEARCH_RESULTS_PER_QUERY=5
TOTAL_CANDIDATE_LIMIT=40
SEARCH_SNIPPET_LIMIT=280
FETCH_CONTENT_LIMIT=900
SEARCH_CACHE_TTL_SECONDS=43200
SEARCH_CACHE_PATH=search_cache.json
SEARCH_STATS_PATH=search_stats.json
TAVILY_DAILY_CREDIT_LIMIT=0

# UX / memory
HEARTBEAT_SECONDS=15
MAX_HISTORY_TURNS=3
MEMORY_QUESTION_CHARS=1200
MEMORY_ANSWER_CHARS=5000
